# ── Discord OAuth ──
# From the Discord Developer Portal (https://discord.com/developers/applications)
# Project: Nation Wheel · Client ID: 1518165332039045150
AUTH_DISCORD_ID=1518165332039045150
AUTH_DISCORD_SECRET=

# ── Auth.js ──
# Generate with: npx auth secret
AUTH_SECRET=

# ── Database (Vercel Postgres) ──
# Set automatically by Vercel when you provision a Postgres database and
# link it to this project (Storage tab -> Connect Project). For local
# dev, pull it with: vercel env pull .env.local
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
